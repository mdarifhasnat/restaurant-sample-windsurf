generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  firstName     String
  lastName      String
  phone         String
  passwordHash  String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  addresses     Address[]
  orders        Order[]
  payments      Payment[]

  @@index([email])
  @@map("users")
}

model Address {
  id                   String   @id @default(cuid())
  userId               String
  label                String
  street               String
  houseNumber          String
  postalCode           String
  city                 String
  deliveryInstructions String?
  isDefault            Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

model Category {
  id            String    @id @default(cuid())
  name          String
  nameDe        String
  description   String?
  descriptionDe String?
  sortOrder     Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  products      Product[]

  @@index([sortOrder])
  @@map("categories")
}

model Product {
  id              String         @id @default(cuid())
  categoryId      String
  name            String
  nameDe          String
  description     String?
  descriptionDe   String?
  price           Decimal        @db.Decimal(10, 2)
  sortOrder       Int            @default(0)
  isActive        Boolean        @default(true)
  isAvailable     Boolean        @default(true)
  preparationTime Int?
  calories        Int?
  allergens       String[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  orderItems      OrderItem[]
  images          ProductImage[]
  category        Category       @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([isActive])
  @@index([isAvailable])
  @@index([sortOrder])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model Order {
  id                   String       @id @default(cuid())
  customerType         CustomerType
  customerId           String?
  email                String
  phone                String
  orderType            OrderType
  status               OrderStatus  @default(PENDING)
  deliveryStreet       String
  deliveryHouseNumber  String
  deliveryPostalCode   String
  deliveryCity         String
  deliveryInstructions String?
  subtotal             Decimal      @db.Decimal(10, 2)
  deliveryFee          Decimal      @db.Decimal(10, 2)
  discountAmount       Decimal      @default(0) @db.Decimal(10, 2)
  total                Decimal      @db.Decimal(10, 2)
  orderNotes           String?
  couponId             String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  confirmedAt          DateTime?
  deliveredAt          DateTime?
  orderNumber          String?      @unique
  items                OrderItem[]
  coupon               Coupon?      @relation(fields: [couponId], references: [id])
  user                 User?        @relation(fields: [customerId], references: [id])
  payments             Payment[]

  @@index([customerId])
  @@index([customerType])
  @@index([status])
  @@index([orderType])
  @@index([createdAt])
  @@index([email])
  @@map("orders")
}

model OrderItem {
  id                   String   @id @default(cuid())
  orderId              String
  productId            String
  productName          String
  productNameDe        String?
  productDescription   String?
  productDescriptionDe String?
  productPrice         Decimal  @db.Decimal(10, 2)
  quantity             Int
  specialInstructions  String?
  createdAt            DateTime @default(now())
  order                Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product              Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Payment {
  id                    String        @id @default(cuid())
  orderId               String
  userId                String?
  method                PaymentMethod
  status                PaymentStatus @default(PENDING)
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("EUR")
  stripePaymentIntentId String?
  paypalPaymentId       String?
  transactionId         String?
  errorMessage          String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  completedAt           DateTime?
  order                 Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user                  User?         @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@index([stripePaymentIntentId])
  @@map("payments")
}

model Coupon {
  id                String     @id @default(cuid())
  code              String     @unique
  type              CouponType
  value             Decimal    @db.Decimal(10, 2)
  minOrderAmount    Decimal?   @db.Decimal(10, 2)
  maxDiscountAmount Decimal?   @db.Decimal(10, 2)
  usageLimit        Int?
  usageCount        Int        @default(0)
  validFrom         DateTime
  validUntil        DateTime?
  isActive          Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  orders            Order[]

  @@index([code])
  @@index([isActive])
  @@index([validFrom])
  @@index([validUntil])
  @@map("coupons")
}

model playing_with_neon {
  id    Int    @id @default(autoincrement())
  name  String
  value Float? @db.Real
}

enum CustomerType {
  GUEST
  REGISTERED
}

enum OrderType {
  DELIVERY
  PICKUP
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERING
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  STRIPE
  PAYPAL
  SOFORT
  GIROPAY
  INVOICE
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_DELIVERY
}
