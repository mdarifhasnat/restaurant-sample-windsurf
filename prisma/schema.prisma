// ============================================================================
// SPEISENREISE.DE - PRODUCTION READY PRISMA SCHEMA
// Single Restaurant Ordering Platform
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum CustomerType {
  GUEST
  REGISTERED
}

enum OrderType {
  DELIVERY
  PICKUP
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERING
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  STRIPE
  PAYPAL
  SOFORT
  GIROPAY
  INVOICE
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_DELIVERY
}

// ============================================================================
// MODELS
// ============================================================================

// ============================================================================
// USER
// Registered customers
// ============================================================================
model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     Boolean   @default(false)
  firstName         String
  lastName          String
  phone             String
  passwordHash      String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // Relations
  addresses         Address[]
  orders            Order[]
  payments          Payment[]
  
  @@index([email])
  @@map("users")
}

// ============================================================================
// ADDRESS
// Saved addresses for registered users
// ============================================================================
model Address {
  id                    String    @id @default(cuid())
  userId                String
  label                 String    // e.g., "Home", "Work"
  street                String
  houseNumber           String
  postalCode            String
  city                  String
  deliveryInstructions  String?
  isDefault             Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  // Relations
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@map("addresses")
}

// ============================================================================
// CATEGORY
// Product categories (e.g., "Appetizers", "Main Courses", "Desserts")
// ============================================================================
model Category {
  id          String    @id @default(cuid())
  name        String
  nameDe      String    // German name
  description String?
  descriptionDe String? // German description
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  products    Product[]
  
  @@index([sortOrder])
  @@map("categories")
}

// ============================================================================
// PRODUCT
// Menu items/dishes
// ============================================================================
model Product {
  id              String    @id @default(cuid())
  categoryId      String
  name            String
  nameDe          String    // German name
  description     String?
  descriptionDe   String?   // German description
  price           Decimal   @db.Decimal(10, 2)
  sortOrder       Int       @default(0)
  isActive        Boolean   @default(true)
  isAvailable     Boolean   @default(true)
  preparationTime Int?      // in minutes
  calories        Int?
  allergens       String[]  // Array of allergens
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  category        Category  @relation(fields: [categoryId], references: [id])
  images          ProductImage[]
  orderItems      OrderItem[]
  
  @@index([categoryId])
  @@index([isActive])
  @@index([isAvailable])
  @@index([sortOrder])
  @@map("products")
}

// ============================================================================
// PRODUCT IMAGE
// Images for products
// ============================================================================
model ProductImage {
  id          String   @id @default(cuid())
  productId   String
  url         String
  alt         String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  
  // Relations
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@index([productId])
  @@map("product_images")
}

// ============================================================================
// ORDER
// Customer orders - supports both guest and registered customers
// ============================================================================
model Order {
  id                    String       @id @default(cuid())
  
  // Customer Information
  customerType          CustomerType
  customerId            String?      // null for guest orders
  email                 String
  phone                 String
  
  // Order Information
  orderType             OrderType    // DELIVERY or PICKUP
  status                OrderStatus  @default(PENDING)
  
  // Delivery Information (stored as snapshot)
  deliveryStreet        String
  deliveryHouseNumber   String
  deliveryPostalCode    String
  deliveryCity          String
  deliveryInstructions  String?
  
  // Order Details
  subtotal              Decimal      @db.Decimal(10, 2)
  deliveryFee           Decimal      @db.Decimal(10, 2)
  discountAmount        Decimal      @db.Decimal(10, 2) @default(0)
  total                 Decimal      @db.Decimal(10, 2)
  orderNotes            String?
  
  // Coupon (optional)
  couponId              String?
  coupon                Coupon?      @relation(fields: [couponId], references: [id])
  
  // Timestamps
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  confirmedAt           DateTime?
  deliveredAt           DateTime?
  
  // Relations
  user                  User?        @relation(fields: [customerId], references: [id])
  items                 OrderItem[]
  payments              Payment[]
  
  @@index([customerId])
  @@index([customerType])
  @@index([status])
  @@index([orderType])
  @@index([createdAt])
  @@index([email])
  @@map("orders")
}

// ============================================================================
// ORDER ITEM
// Individual items in an order (snapshot of product data)
// ============================================================================
model OrderItem {
  id                    String    @id @default(cuid())
  orderId               String
  productId             String
  
  // Product snapshot (to preserve order history even if product changes)
  productName            String
  productNameDe          String?
  productDescription     String?
  productDescriptionDe   String?
  productPrice           Decimal    @db.Decimal(10, 2)
  
  quantity              Int
  specialInstructions   String?
  
  createdAt             DateTime  @default(now())
  
  // Relations
  order                 Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product               Product   @relation(fields: [productId], references: [id])
  
  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ============================================================================
// PAYMENT
// Payment records for orders
// ============================================================================
model Payment {
  id              String        @id @default(cuid())
  orderId         String
  userId          String?       // optional, for registered users
  
  // Payment Details
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("EUR")
  
  // External Payment Provider Data
  stripePaymentIntentId String?  // For Stripe
  paypalPaymentId        String?  // For PayPal
  transactionId          String?  // Generic transaction ID
  
  // Error handling
  errorMessage    String?
  
  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  completedAt     DateTime?
  
  // Relations
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user            User?         @relation(fields: [userId], references: [id])
  
  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@index([stripePaymentIntentId])
  @@map("payments")
}

// ============================================================================
// COUPON
// Discount coupons
// ============================================================================
model Coupon {
  id              String      @id @default(cuid())
  code            String      @unique
  type            CouponType
  value           Decimal     @db.Decimal(10, 2) // Percentage or fixed amount
  minOrderAmount  Decimal?    @db.Decimal(10, 2)
  maxDiscountAmount Decimal?  @db.Decimal(10, 2)
  usageLimit      Int?        // null = unlimited
  usageCount      Int         @default(0)
  validFrom       DateTime
  validUntil      DateTime?
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  // Relations
  orders          Order[]
  
  @@index([code])
  @@index([isActive])
  @@index([validFrom])
  @@index([validUntil])
  @@map("coupons")
}
